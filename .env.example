# Heatseeker configuration — copy to .env and adjust. All variables optional.
# Data root (SQLite DB, raw evidence, exports, backups, logs live under here)
#HEATSEEKER_DATA_DIR=data
# Override the derived SQLite URL entirely (rarely needed)
#HEATSEEKER_DATABASE_URL=sqlite+pysqlite:///data/heatseeker.db
# Local API binding — keep on 127.0.0.1 (spec §32.1)
#HEATSEEKER_API_HOST=127.0.0.1
#HEATSEEKER_API_PORT=8100
#HEATSEEKER_LOG_LEVEL=INFO
# RUNNING jobs with a heartbeat older than this are requeued by the worker's reaper
#HEATSEEKER_STALE_JOB_SECONDS=120
# Robots is advisory by default for this private research tool. Set "enforce" to block
# disallowed URLs globally; either mode still records robots status in evidence provenance.
#HEATSEEKER_ROBOTS_POLICY=ignore
# Optional HTTP(S)/SOCKS5 proxy for policy checks, collection, and crawling.
#HEATSEEKER_FETCH_PROXY_URL=http://127.0.0.1:8080
