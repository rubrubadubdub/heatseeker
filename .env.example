# Heatseeker configuration — copy to .env and adjust. All variables optional.
# Data root (SQLite DB, raw evidence, exports, backups, logs live under here)
#HEATSEEKER_DATA_DIR=data
# Override the derived SQLite URL entirely (rarely needed)
#HEATSEEKER_DATABASE_URL=sqlite+pysqlite:///data/heatseeker.db
# Local API binding — keep on 127.0.0.1 (spec §32.1)
#HEATSEEKER_API_HOST=127.0.0.1
#HEATSEEKER_API_PORT=8100
#HEATSEEKER_LOG_LEVEL=INFO
# RUNNING jobs with a heartbeat older than this are requeued by the worker's reaper
#HEATSEEKER_STALE_JOB_SECONDS=120
# Robots.txt is honoured by default. Set "ignore" only for endpoints you are authorised
# to collect; robots status is recorded in evidence provenance in either mode. A
# per-source override is also available for authorised exceptions.
#HEATSEEKER_ROBOTS_POLICY=enforce
# Untrusted document/image processing limits. OCR/vision stay disabled until a provider
# is deliberately configured; raw evidence and native text extraction still work.
#HEATSEEKER_DOCUMENT_MAX_PAGES=250
#HEATSEEKER_DOCUMENT_MAX_EXTRACTED_CHARS=2000000
#HEATSEEKER_IMAGE_MAX_PIXELS=40000000
#HEATSEEKER_EVIDENCE_OCR_ENABLED=false
#HEATSEEKER_EVIDENCE_VISION_ENABLED=false
# Agentic source scouting. Authenticate the selected CLI under the same Windows user
# that launches Heatseeker; secrets remain in the provider's credential store.
#HEATSEEKER_AI_ENABLED=true
#HEATSEEKER_AI_CODEX_COMMAND=codex
#HEATSEEKER_AI_CLAUDE_COMMAND=claude
#HEATSEEKER_AI_SCOUT_TIMEOUT_SECONDS=900
#HEATSEEKER_AI_SCOUT_MAX_OUTPUT_BYTES=2097152
